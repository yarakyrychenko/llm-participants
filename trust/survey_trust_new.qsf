g a ${q:\/\/QID280\/ChoiceGroup\/SelectedChoices}\u00a0to you? \u00a0 Below is a range fro.","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["5"],"Choices":{"5":{"Display":"&nbsp;"}},"Configuration":{"CSSliderMax":100,"CSSliderMin":0,"CustomStart":true,"GridLines":10,"MobileFirst":true,"NotApplicable":false,"NumDecimals":"0","QuestionDescriptionOption":"UseText","ShowValue":true,"SliderStartPositions":{"5":0}},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Labels":{"1":{"Display":"Not important <br> at all"},"2":{"Display":"Moderately <br> important"},"3":{"Display":"Extremely <br> important"}},"Language":[],"NextAnswerId":4,"NextChoiceId":6,"QuestionDescription":"How important is being a ${q:\/\/QID280\/ChoiceGroup\/SelectedChoices}\u00a0to you? \u00a0 Below is a range fro...","QuestionText":"<div>How important is being a ${q:\/\/QID280\/ChoiceGroup\/SelectedChoices}&nbsp;to you?<\/div>\n\n<div>&nbsp;<\/div>\n\n<div><span style=\"font-size:13px;\">Below is a range from 0 to 100 indicating how important this is to you. Click on any space within this range and a bar will appear. Feel free to move that bar around to the number that best represents your answer.<\/span><\/div>","QuestionText_Unsafe":"<div>How important is being a ${q:\/\/QID280\/ChoiceGroup\/SelectedChoices}&nbsp;to you?<\/div>\n\n<div>&nbsp;<\/div>\n\n<div><span style=\"font-size:13px;\">Below is a range from 0 to 100 indicating how important this is to you. Click on any space within this range and a bar will appear. Feel free to move that bar around to the number that best represents your answer.<\/span><\/div>","QuestionType":"Slider","Selector":"HBAR","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"DataExportTag":"partisan_importance","QuestionID":"QID281","ChoiceDataExportTags":false}},{"SurveyID":"SV_b2ULL6XxhpfseDY","Element":"SQ","PrimaryAttribute":"QID282","SecondaryAttribute":"Timi